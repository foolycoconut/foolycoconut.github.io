---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Shengming Zhou" description="Personal homepage for Shengming Zhou.">
  <section class="page-intro">
    <p class="eyebrow">Computer Science Student</p>
    <h1 class="page-title">Shengming Zhou</h1>
    <div class="page-body space-y-6">
      <p>
        I am a computer science student at the University of Minnesota. My background
        also includes undergraduate study in mathematics, and I am broadly interested
        in databases, mathematical methods, and research-oriented systems work.
      </p>
      <p>
        This site is intentionally simple. The homepage is just an introduction, while
        the rest of the material lives in separate pages for blog posts, contact
        details, and a downloadable CV.
      </p>
    </div>
  </section>

  <section class="simple-grid">
    <article class="card">
      <p class="eyebrow">Current Interests</p>
      <h2 class="card-title">Research and study</h2>
      <p class="body-copy">
        I am especially interested in databases, mathematical methods, and the way
        theoretical ideas can be turned into concrete computational work.
      </p>
    </article>
    <article class="card">
      <p class="eyebrow">Pages</p>
      <h2 class="card-title">Navigation</h2>
      <ul class="subtle-list">
        <li><a class="muted-link" href="/cv">CV</a> for a concise academic record.</li>
        <li><a class="muted-link" href="/contact">Contact</a> for email and external links.</li>
        <li><a class="muted-link" href="/blog">Blog</a> for occasional notes and future writing.</li>
      </ul>
    </article>
  </section>

  <section class="academic-block">
    <p class="eyebrow">Brief Note</p>
    <p class="body-copy mt-4">
      I prefer this site to remain selective rather than exhaustive. It is meant to be
      a clear starting point, with the CV and contact pages carrying most of the formal
      information.
    </p>
  </section>
</BaseLayout>
